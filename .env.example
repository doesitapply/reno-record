# Reno Record production environment template
# Do not commit real secret values. Set these in the hosting provider's environment/secret manager.

NODE_ENV=production
NODE_VERSION=22.13.0
PORT=3000

# Required server/runtime secrets
JWT_SECRET=
DATABASE_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Required if frontend Forge-backed components are enabled
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional transactional email. If omitted, email is skipped safely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
